---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
	{
		title: "Ongles Longs.",
		text: "Extensions sculptées avec une ligne élégante et une finition couture."
	},
	{
		title: "Court Simple.",
		text: "Manucure nette et sophistiquée pour un rendu minimaliste haut de gamme."
	},
	{
		title: "French.",
		text: "French classique ou revisitée, précise, fine et toujours équilibrée."
	},
	{
		title: "Nail Art.",
		text: "Créations personnalisées du détail subtil à la composition signature."
	},
	{
		title: "Pédicure.",
		text: "Soin expert et finition impeccable pour une allure soignée jusqu’au bout."
	}
];

const prices = [
	{ label: "Pose complète (French / Babyboomer)", value: "45 EUR" },
	{ label: "Gel + VSP / Gel simple", value: "40 EUR" },
	{ label: "BIAB", value: "35 EUR" },
	{ label: "Dépose + manucure", value: "15 EUR" }
];

const reviews = [
	{
		text: "Je suis arrivée avec une casse sur deux ongles, tout a été réparé proprement et sans douleur.",
		name: "Mariam T."
	},
	{
		text: "Babyboomer fait il y a presque 3 semaines et ça tient encore super bien, je suis bluffée.",
		name: "Sarah B."
	},
	{
		text: "Je suis venue avec une inspi Pinterest et le rendu est plus fin que la photo de départ.",
		name: "Camille R."
	},
	{
		text: "Très bon accueil, on prend le temps de choisir la forme et la longueur qui vont vraiment à mes mains.",
		name: "Nora M."
	},
	{
		text: "Je travaille beaucoup avec mes mains et la tenue est nickel au quotidien, même après une semaine chargée.",
		name: "Léa T."
	},
	{
		text: "French ultra propre, pas épaisse, exactement ce que je voulais pour un événement.",
		name: "Ines D."
	},
	{
		text: "Premier rendez-vous BIAB pour moi: ongles plus solides et rendu naturel, sans effet trop chargé.",
		name: "Julie P."
	},
	{
		text: "J'ai pris un nail art discret et élégant, ça attire l'œil sans en faire trop.",
		name: "Maya S."
	},
	{
		text: "Ponctuelle, douce et très minutieuse sur les détails. On sent l'expérience et le sérieux.",
		name: "Émilie K."
	},
	{
		text: "Le timing est respecté du début à la fin, c'est parfait quand on a une journée bien remplie.",
		name: "Sonia F."
	},
	{
		text: "Très bons conseils sur la longueur selon la forme de mes mains, le résultat est beaucoup plus harmonieux.",
		name: "Chloé V."
	},
	{
		text: "Je reviens tous les mois et je ne suis jamais déçue, c'est devenu mon rendez-vous habituel.",
		name: "Yasmine C."
	}
];
---

<BaseLayout title="KS Studio | Onglerie haut de gamme">
	<div class="home-shell">
		<section class="hero-panel">
			<picture>
				<source
					type="image/avif"
					srcset="/optimized/hero-768.avif 768w, /optimized/hero-1200.avif 1200w, /optimized/hero-1400.avif 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
				/>
				<source
					type="image/jpeg"
					srcset="/optimized/hero-768.jpg 768w, /optimized/hero-1200.jpg 1200w, /optimized/hero-1400.jpg 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
				/>
				<img
					src="/optimized/hero-1200.jpg"
					srcset="/optimized/hero-768.jpg 768w, /optimized/hero-1200.jpg 1200w, /optimized/hero-1400.jpg 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
					alt="Image d'accueil onglerie"
					class="hero-bg"
					loading="eager"
					fetchpriority="high"
					decoding="async"
					width="1400"
					height="934"
				/>
			</picture>
			<div class="hero-shade"></div>
				<div class="hero-content">
					<div class="hero-center">
						<h1>
							<span class="hero-title-line">L'élégance des</span>
							<span class="hero-title-line">Ongles signé</span>
							<span class="hero-title-accent">KS Studio</span>
						</h1>
						<p>
							Des finitions précises, une tenue durable et un rendu haut de gamme dès le premier rendez-vous.
						</p>
						<a class="hero-cta" href="/reservation">Prendre rendez-vous maintenant</a>
					</div>
				</div>
			</section>

		<section class="services-strip" id="prestations">
			{
				services.map((service) => (
					<article
						class={`service-tile ${service.title === "Pédicure." ? "service-tile-mobile-hidden" : ""}`}
					>
						<h2>{service.title}</h2>
						<p>{service.text}</p>
						<span aria-hidden="true">-&gt;</span>
					</article>
				))
			}
		</section>

		<section class="wide-feature">
			<picture>
				<source
					type="image/avif"
					srcset="/optimized/studio-768.avif 768w, /optimized/studio-1200.avif 1200w, /optimized/studio-1400.avif 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
				/>
				<source
					type="image/jpeg"
					srcset="/optimized/studio-768.jpg 768w, /optimized/studio-1200.jpg 1200w, /optimized/studio-1400.jpg 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
				/>
				<img
					src="/optimized/studio-1200.jpg"
					srcset="/optimized/studio-768.jpg 768w, /optimized/studio-1200.jpg 1200w, /optimized/studio-1400.jpg 1400w"
					sizes="(max-width: 760px) 95vw, (max-width: 1320px) 98vw, 1320px"
					alt="Ambiance du salon"
					class="media-smooth"
					loading="lazy"
					decoding="async"
					width="1400"
					height="934"
				/>
			</picture>
			<div class="wide-feature-copy">
				<h2>Un studio raffiné, pensé pour votre moment.</h2>
				<p>
					Chaque rendez-vous combine confort, hygiène irréprochable et précision
					technique pour un résultat qui se remarque.
				</p>
			</div>
		</section>

		<section class="gallery-strip" id="realisations">
			<div class="gallery-head">
				<p class="gallery-kicker">Collection signature</p>
				<h2>Des poses sculptées dans le détail.</h2>
				<p>
					Forme, brillance, équilibre: chaque réalisation est pensée pour mettre vos mains en valeur.
				</p>
			</div>
			<div class="gallery-rail-wrap">
