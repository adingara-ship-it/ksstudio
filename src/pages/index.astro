								srcset="/optimized/ongles5-360.jpg 360w, /optimized/ongles5-560.jpg 560w, /optimized/ongles5-860.jpg 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
							/>
							<img
								src="/optimized/ongles5-560.jpg"
								srcset="/optimized/ongles5-360.jpg 360w, /optimized/ongles5-560.jpg 560w, /optimized/ongles5-860.jpg 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
								alt="French rose sur ongles carrés"
								class="work-photo work-photo-5 media-smooth"
								loading="lazy"
								decoding="async"
								width="1152"
								height="2048"
							/>
						</picture>
