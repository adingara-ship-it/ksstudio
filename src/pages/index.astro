		<section class="price-panel" id="prix">
			<h2>Prestations principales</h2>
			<div class="price-grid">
				{
					prices.map((item) => (
						<article class="price-tile">
							<p>{item.label}</p>
							<strong>{item.value}</strong>
						</article>
					))
				}
			</div>
			<p class="section-intro">Suppléments (tailles et nail art) disponibles lors de la réservation.</p>
		</section>

		<section class="review-panel" id="avis">
			<h2>Un service haut de gamme, validé par nos clientes.</h2>
			<div
				class="review-carousel"
				data-review-carousel
				data-reviews={JSON.stringify(reviews)}
			>
				<article class="review-card review-slot review-slot-left" data-slot="left" aria-hidden="true">
					<p class="review-text">"{reviews[reviews.length - 1].text}"</p>
					<span class="review-author">{reviews[reviews.length - 1].name}</span>
				</article>
				<article class="review-card review-slot review-slot-center" data-slot="center">
					<p class="review-text">"{reviews[0].text}"</p>
					<span class="review-author">{reviews[0].name}</span>
				</article>
				<article class="review-card review-slot review-slot-right" data-slot="right" aria-hidden="true">
					<p class="review-text">"{reviews[1].text}"</p>
					<span class="review-author">{reviews[1].name}</span>
				</article>
			</div>
		</section>

		<section class="bottom-cta">
			<h2>Prête à réserver votre prochaine pose signature ?</h2>
			<p>
				Choisissez votre prestation et votre créneau en moins d'une minute.
			</p>
				<a class="btn" href="/reservation">Réserver maintenant</a>
			</section>
		</div>

	<script>
		(() => {
			const carousel = document.querySelector("[data-review-carousel]");
			if (!(carousel instanceof HTMLElement)) return;

			let reviews = [];
			try {
				reviews = JSON.parse(carousel.dataset.reviews ?? "[]");
			} catch {
				reviews = [];
			}
			if (!Array.isArray(reviews) || reviews.length < 3) return;

			const leftCard = carousel.querySelector('[data-slot="left"]');
			const centerCard = carousel.querySelector('[data-slot="center"]');
			const rightCard = carousel.querySelector('[data-slot="right"]');
			if (!(leftCard instanceof HTMLElement)) return;
			if (!(centerCard instanceof HTMLElement)) return;
			if (!(rightCard instanceof HTMLElement)) return;

			let centerIndex = 0;
			const holdDuration = 4800;
			const switchDuration = 460;
			const swapMoment = 230;
			let holdTimerId = null;
			let swapTimerId = null;
			let endTimerId = null;
			let isSwitching = false;
			let isInViewport = false;
			let isPageVisible = !document.hidden;

			const getReviewIndex = (offset) =>
				(centerIndex + offset + reviews.length) % reviews.length;

			const setCardContent = (card, review) => {
				const textNode = card.querySelector(".review-text");
				const authorNode = card.querySelector(".review-author");

				if (textNode) textNode.textContent = `"${review.text}"`;
				if (authorNode) authorNode.textContent = review.name;
			};

			const render = () => {
				setCardContent(leftCard, reviews[getReviewIndex(-1)]);
				setCardContent(centerCard, reviews[getReviewIndex(0)]);
				setCardContent(rightCard, reviews[getReviewIndex(1)]);
			};

			const canRun = () => isInViewport && isPageVisible;

			const queueNext = () => {
				if (!canRun()) return;
				holdTimerId = window.setTimeout(() => {
					if (!canRun()) return;
					if (isSwitching) return;
					isSwitching = true;
					carousel.classList.add("is-switching");

					swapTimerId = window.setTimeout(() => {
						if (!canRun()) return;
						centerIndex = (centerIndex + 1) % reviews.length;
						render();
					}, swapMoment);

					endTimerId = window.setTimeout(() => {
						carousel.classList.remove("is-switching");
						isSwitching = false;
						if (!canRun()) return;
						queueNext();
					}, switchDuration);
				}, holdDuration);
			};

			const stop = () => {
				if (holdTimerId !== null) {
					window.clearTimeout(holdTimerId);
					holdTimerId = null;
				}
				if (swapTimerId !== null) {
					window.clearTimeout(swapTimerId);
					swapTimerId = null;
				}
				if (endTimerId !== null) {
					window.clearTimeout(endTimerId);
					endTimerId = null;
				}
				isSwitching = false;
				carousel.classList.remove("is-switching");
			};

			const resume = () => {
				if (!canRun()) return;
				if (holdTimerId !== null || isSwitching) return;
				queueNext();
			};

			render();

			if ("IntersectionObserver" in window) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							isInViewport = entry.isIntersecting;
							if (!canRun()) {
								stop();
								return;
							}
							resume();
						});
					},
					{
						threshold: 0.2
					}
				);
				observer.observe(carousel);
			} else {
				isInViewport = true;
			}

			document.addEventListener("visibilitychange", () => {
				isPageVisible = !document.hidden;
				if (!canRun()) {
					stop();
					return;
				}
				resume();
			});

			window.addEventListener("pagehide", () => {
				stop();
			});

			resume();
		})();
	</script>
</BaseLayout>
