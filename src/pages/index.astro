							/>
							<img
								src="/optimized/ongles2-560.jpg"
								srcset="/optimized/ongles2-360.jpg 360w, /optimized/ongles2-560.jpg 560w, /optimized/ongles2-860.jpg 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
