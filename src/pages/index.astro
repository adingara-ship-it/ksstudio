								srcset="/optimized/work2-360.jpg 360w, /optimized/work2-560.jpg 560w, /optimized/work2-860.jpg 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
							/>
							<img
								src="/optimized/work2-560.jpg"
								srcset="/optimized/work2-360.jpg 360w, /optimized/work2-560.jpg 560w, /optimized/work2-860.jpg 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
								alt="Nail art avec détails rouges et motifs"
								class="work-photo work-photo-2 media-smooth"
								loading="lazy"
								decoding="async"
								width="900"
								height="1600"
							/>
						</picture>
					<figcaption>Nail art accent</figcaption>
					</figure>
					<figure class="gallery-card">
						<picture>
							<source
								type="image/avif"
								srcset="/optimized/ongles5-360.avif 360w, /optimized/ongles5-560.avif 560w, /optimized/ongles5-860.avif 860w"
								sizes="(max-width: 520px) 64vw, (max-width: 760px) 58vw, (max-width: 1120px) 34vw, 22vw"
