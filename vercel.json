{
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/optimized/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*)\\.(png|jpg|jpeg|webp|avif|svg|ico)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(robots\\.txt|sitemap\\.xml)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=3600, stale-while-revalidate=86400"
				}
			]
		}
	]
}
